{
  // Show only the documented Strudel globals in completions. Auto-imports are
  // disabled so the same name from "@strudel/core" / "@strudel/mini" doesn't
  // appear as a second, undocumented suggestion.
  "lsp": {
    "vtsls": {
      "settings": {
        "javascript": { "suggest": { "autoImports": false } },
        "typescript": { "suggest": { "autoImports": false } }
      }
    }
  },
  // Don't reformat JS on save — pattern files (live.js, library/, cookbook/) are
  // laid out by hand for live coding; the formatter would collapse short lines.
  "languages": {
    "JavaScript": { "format_on_save": "off" }
  }
}
