{
  // Settings for the editor's JS/TS language service (Zed, VS Code, etc).
  // strudel.d.ts is auto-associated with strudel.js by basename, so importing
  // from './strudel.js' gives autocomplete + hover with no extra config here.
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "checkJs": false,
    "allowJs": true,
    "noEmit": true
  },
  "include": ["*.mjs", "*.js", "*.d.ts", "scripts/**/*.mjs"]
}
