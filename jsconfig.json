{
  // Settings for the editor's JS/TS language service (Zed, VS Code, etc).
  // framework/strudel.globals.d.ts declares every Strudel function as an ambient
  // global, so session files (sessions/<name>/*.js) need no imports and get
  // autocomplete/hover everywhere. `lib` is pinned to esnext (no DOM) so the
  // globals don't collide with DOM names like `frames`.
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": ["esnext"],
    "checkJs": false,
    "allowJs": true,
    "noEmit": true
  },
  "include": ["framework/**/*.js", "framework/**/*.d.ts", "sessions/**/*.js", "library/**/*.js"]
}
